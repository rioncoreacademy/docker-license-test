MYSQL_ROOT_PASSWORD=localtestroot
DB_PASS=localtestpass

# Protects the /admin/generate and /admin/lookup endpoints (public/admin.html).
# Pick any random string -- this is a shared password, not a DB credential.
# Leave blank to disable the admin page entirely (403 on both endpoints).
ADMIN_TOKEN=change-me-to-something-random

# Encryption key handed back by /activate and /validate for any license
# whose product_id is NULL (legacy/full-access licenses, e.g. the two TEST-*
# seed rows). Folder-scoped licenses use their product's own key instead --
# see the "Products" section in README.md. Required once /activate/
# /validate start returning encryption_key -- an unset value means every
# legacy license silently gets an empty key.
DEFAULT_ENCRYPTION_KEY=change-me-to-a-real-encryption-key
